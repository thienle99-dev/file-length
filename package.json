{
  "name": "file-length-visualizer",
  "displayName": "File Length & Complexity Visualizer",
  "description": "Displays line counts and complexity insights next to file names in the Explorer.",
  "version": "1.0.3",
  "icon": "icon.png",
  "publisher": "ChiThien",
  "author": {
    "name": "Chi Thien",
    "email": "chithien0909@gmail.com"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/thienle99-dev/file-length.git"
  },
  "engines": {
    "vscode": "^1.75.0"
  },
  "homepage": "https://github.com/thienle99-dev/file-length/blob/main/README.md",
  "bugs": {
    "url": "https://github.com/thienle99-dev/file-length/issues"
  },
  "extensionDependencies": [
    "vscode.git"
  ],
  "keywords": [
    "line count",
    "complexity",
    "git",
    "visualizer",
    "heatmap",
    "explorer",
    "sloc"
  ],
  "categories": [
    "Visualization",
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "file-length-explorer",
          "title": "File Length",
          "icon": "icon.png"
        }
      ]
    },
    "views": {
      "file-length-explorer": [
        {
          "id": "file-length-sidebar",
          "name": "Line Statistics",
          "type": "tree",
          "icon": "icon.png"
        }
      ]
    },
    "commands": [
      {
        "command": "file-length-visualizer.showDashboard",
        "title": "File Length: Show Analytics Dashboard",
        "category": "File Length"
      },
      {
        "command": "file-length-visualizer.refreshSidebar",
        "title": "Refresh Statistics",
        "icon": "$(refresh)",
        "category": "File Length"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "file-length-visualizer.refreshSidebar",
          "when": "view == file-length-sidebar",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "Line Count Explorer",
      "properties": {
        "lineCount.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable/Disable line count decorations."
        },
        "lineCount.showOnlyNonEmptyLines": {
          "type": "boolean",
          "default": false,
          "description": "If enabled, blank lines will not be counted."
        },
        "lineCount.ignoreComments": {
          "type": "boolean",
          "default": false,
          "description": "If enabled, lines containing only comments will be ignored."
        },
        "lineCount.showComplexity": {
          "type": "boolean",
          "default": true,
          "description": "Show complexity warning icon (⚠) for high-complexity files."
        },
        "lineCount.showHeatmap": {
          "type": "boolean",
          "default": true,
          "description": "Change file color in Explorer based on line count (Red > 1000, Orange > 500, Green < 100)."
        },
        "lineCount.showGitDelta": {
          "type": "boolean",
          "default": true,
          "description": "Show line count change compared to Git HEAD."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "pnpm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "pnpm run compile && pnpm run lint",
    "lint": "eslint src --ext ts"
  },
  "devDependencies": {
    "@types/vscode": "^1.75.0",
    "@types/node": "16.x",
    "typescript": "^4.9.5",
    "eslint": "^8.36.0"
  }
}
